# === Flights: default = OpenSky Network (no local antenna) ===
# Unset FLIGHTS_DATA_URL to use https://opensky-network.org (anonymous or OAuth).
# Bbox is centered on FLIGHTS_CENTER_LAT/LON (defaults: central Singapore); adjust for your home.
# FLIGHTS_CENTER_LAT=1.3521
# FLIGHTS_CENTER_LON=103.8198
# FLIGHTS_BBOX_HALF_DEG=0.24
# Throttle how often we call OpenSky (default 180000 = 3 min) to protect daily API credits
# OPENSKY_CACHE_MS=180000
# Optional — higher rate limits: create an API client at https://opensky-network.org/ → Account
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=
#
# Use a local readsb/FR24/dump1090 JSON URL instead of OpenSky:
# FLIGHTS_DATA_URL=http://127.0.0.1:8754/flights.json
# Or force OpenSky even if the line above is still in your file:
# FLIGHTS_PROVIDER=opensky
#
# FLIGHTS_PROVIDER=off
# (or FLIGHTS_DATA_URL=off)

# === Display rotation ===
# Set to 0 (normal) or 180 (inverted). Default: 0
# DISPLAY_ROTATION=0
